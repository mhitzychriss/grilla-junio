<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grilla Junio 2026 — Mhitzy Chriss</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d0d0f;
  --bg2: #141416;
  --bg3: #1c1c1f;
  --bg4: #232326;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.13);
  --text: #f0eee8;
  --text2: #9a9890;
  --text3: #4a4846;
  --accent: #e8855a;
  --accent2: #f0a882;
  --gold: #c9a96e;
  --line: rgba(232,133,90,0.18);

  --ig: #c13584;
  --ig-bg: rgba(193,53,132,0.10);
  --ig-border: rgba(193,53,132,0.28);

  --tk: #69c9d0;
  --tk-bg: rgba(105,201,208,0.08);
  --tk-border: rgba(105,201,208,0.25);

  --li: #0a66c2;
  --li-bg: rgba(10,102,194,0.10);
  --li-border: rgba(10,102,194,0.28);

  --st: rgba(255,255,255,0.06);
  --st-border: rgba(255,255,255,0.12);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  line-height: 1.6;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ── HERO ── */
.hero {
  padding: 60px 32px 48px;
  max-width: 860px;
  margin: 0 auto;
  position: relative;
}

.hero::after {
  content: '';
  display: block;
  width: 60px;
  height: 1px;
  background: var(--accent);
  margin-top: 32px;
  opacity: 0.5;
}

.hero-eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 14px;
}

.hero-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(36px, 6vw, 58px);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -.01em;
  margin-bottom: 14px;
  color: var(--text);
}

.hero-title em {
  font-style: italic;
  color: var(--accent2);
}

.hero-sub {
  font-size: 13px;
  color: var(--text2);
  font-weight: 300;
  max-width: 420px;
  line-height: 1.7;
}

.hero-meta {
  display: flex;
  gap: 24px;
  margin-top: 28px;
  flex-wrap: wrap;
}

.hero-stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.hero-stat-n {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--text);
  line-height: 1;
}

.hero-stat-l {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--text3);
}

/* ── FILTERS ── */
.filters-wrap {
  padding: 0 32px 32px;
  max-width: 860px;
  margin: 0 auto;
}

.filters {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.filter-btn {
  font-family: 'DM Sans', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: 6px;
  border: 1px solid var(--border2);
  background: var(--bg2);
  color: var(--text2);
  cursor: pointer;
  transition: all .18s;
}

.filter-btn:hover { color: var(--text); border-color: rgba(255,255,255,0.22); }

.filter-btn.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
}

/* ── TIMELINE ── */
.timeline {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 32px 80px;
  position: relative;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 56px;
  top: 0;
  bottom: 0;
  width: 1px;
  background: linear-gradient(to bottom, transparent, var(--line) 8%, var(--line) 92%, transparent);
}

/* ── DAY ROW ── */
.day-row {
  display: grid;
  grid-template-columns: 48px 1fr;
  gap: 0 20px;
  margin-bottom: 2px;
  transition: opacity .2s;
}

.day-row.hidden { display: none; }

.day-anchor {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 18px;
  position: relative;
  z-index: 1;
}

.day-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--bg3);
  border: 1.5px solid var(--border2);
  flex-shrink: 0;
  margin-bottom: 4px;
  transition: background .2s, border-color .2s;
}

.day-row.has-heavy .day-dot {
  background: var(--accent);
  border-color: var(--accent);
  box-shadow: 0 0 10px rgba(232,133,90,0.4);
}

.day-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text3);
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  line-height: 1;
}

/* ── CONTENT BLOCK ── */
.content-block {
  padding: 14px 0 20px;
  border-bottom: 1px solid var(--border);
}

.day-date {
  font-family: 'Playfair Display', serif;
  font-size: 11px;
  font-style: italic;
  color: var(--text3);
  margin-bottom: 10px;
  letter-spacing: .02em;
}

.cards-stack {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* ── CARD ── */
.card {
  border-radius: 10px;
  padding: 14px 16px;
  border: 1px solid;
  position: relative;
  overflow: hidden;
  transition: transform .15s, box-shadow .15s;
}

.card:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 24px rgba(0,0,0,0.3);
}

.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 3px; height: 100%;
}

/* Historia matutina card */
.card.historia {
  background: var(--st);
  border-color: var(--st-border);
}
.card.historia::before { background: rgba(255,255,255,0.15); }

/* IG */
.card.ig { background: var(--ig-bg); border-color: var(--ig-border); }
.card.ig::before { background: var(--ig); }

/* TikTok */
.card.tiktok { background: var(--tk-bg); border-color: var(--tk-border); }
.card.tiktok::before { background: var(--tk); }

/* LinkedIn */
.card.linkedin { background: var(--li-bg); border-color: var(--li-border); }
.card.linkedin::before { background: var(--li); }

/* Multi-plataforma */
.card.multi {
  background: linear-gradient(135deg, var(--ig-bg), var(--tk-bg));
  border-color: rgba(255,255,255,0.10);
}
.card.multi::before {
  background: linear-gradient(to bottom, var(--ig), var(--tk));
}

/* ── CARD HEADER ── */
.card-head {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}

.platform-chips {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
}

.chip {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: 2px 7px;
  border-radius: 4px;
}

.chip-ig { background: rgba(193,53,132,0.2); color: #e27abe; }
.chip-tk { background: rgba(105,201,208,0.15); color: #69c9d0; }
.chip-li { background: rgba(10,102,194,0.2); color: #5a9de8; }
.chip-st { background: rgba(255,255,255,0.07); color: var(--text3); }

.format-badge {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: var(--text3);
  margin-left: auto;
}

/* ── CARD BODY ── */
.card-title {
  font-family: 'Playfair Display', serif;
  font-size: 14px;
  font-weight: 700;
  line-height: 1.35;
  color: var(--text);
  margin-bottom: 0;
}

.card.ig .card-title { color: #f0c0e0; }
.card.tiktok .card-title { color: #a0e8ec; }
.card.linkedin .card-title { color: #a0c4f0; }
.card.multi .card-title { color: var(--text); }

/* ── HISTORIA MATUTINA (special) ── */
.card.historia .card-title {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-weight: 400;
  font-size: 13px;
  color: var(--text2);
  line-height: 1.55;
}

.morning-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--text3);
  margin-bottom: 6px;
  display: flex;
  align-items: center;
  gap: 5px;
}

.morning-label::before {
  content: '';
  width: 12px;
  height: 1px;
  background: var(--text3);
  display: inline-block;
}

/* ── WEEK SEPARATOR ── */
.week-sep {
  grid-column: 1 / -1;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 24px 0 6px;
}

.week-label-text {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--accent);
  white-space: nowrap;
}

.week-line {
  flex: 1;
  height: 1px;
  background: var(--border);
}

/* ── EMPTY STATE ── */
.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: var(--text3);
  font-size: 13px;
  display: none;
}

/* ── LEGEND ── */
.legend-wrap {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 32px 40px;
}

.legend {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  padding: 14px 18px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 10px;
}

.legend-title {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text3);
  width: 100%;
  margin-bottom: 6px;
}

.leg {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--text2);
}

.leg-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ── RESPONSIVE ── */
@media (max-width: 600px) {
  .hero { padding: 40px 20px 32px; }
  .filters-wrap { padding: 0 20px 24px; }
  .timeline { padding: 0 20px 60px; }
  .timeline::before { left: 38px; }
  .legend-wrap { padding: 0 20px 40px; }
  .hero-title { font-size: 32px; }
}

/* ── SCROLL ANIMATION ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

.day-row {
  animation: fadeUp .35s ease both;
}

.day-row:nth-child(1) { animation-delay: .04s }
.day-row:nth-child(2) { animation-delay: .08s }
.day-row:nth-child(3) { animation-delay: .12s }
.day-row:nth-child(4) { animation-delay: .16s }
.day-row:nth-child(5) { animation-delay: .20s }
.day-row:nth-child(6) { animation-delay: .24s }
.day-row:nth-child(7) { animation-delay: .28s }
.day-row:nth-child(8) { animation-delay: .32s }
.day-row:nth-child(9) { animation-delay: .36s }
</style>
</head>
